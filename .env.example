# ─────────────────────────────────────────────────────────
# LeadForge PRO — Environment Variables
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────────────────

# Supabase (https://supabase.com → New Project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# App URL (no trailing slash)
# Local:      http://localhost:3000
# Production: https://leadforge-pro.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional live lead-research providers.
# If SERPAPI_API_KEY is omitted, the app falls back to public Bing result pages.
# ANTHROPIC_API_KEY is optional and only used to enrich public-web findings.
# RENTCAST_API_KEY enables structured public-record property search.
# When RENTCAST_API_KEY is set, LeadForge will combine direct property records with web research.
# For the strongest real-lead results in production, set RENTCAST_API_KEY.
# RENTCAST_API_KEY=
# SERPAPI_API_KEY=
# ANTHROPIC_API_KEY=
# LEADFORGE_AI_MODEL=claude-3-5-sonnet-latest

# Admin access is controlled by `profiles.is_admin`.
# Promote an admin by setting `is_admin = true` on that user's row in `profiles`.
