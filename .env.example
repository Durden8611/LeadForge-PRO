# ─────────────────────────────────────────────────────────
# LeadForge PRO — Environment Variables
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────────────────

# Supabase (https://supabase.com → New Project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# App URL (no trailing slash)
# Local:      http://localhost:3000
# Production: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: create a `profiles` table in your Supabase DB to store usernames and display names.
# SQL example:
# create table profiles (
#   id uuid primary key references auth.users(id) on delete cascade,
#   username text unique,
#   full_name text,
#   created_at timestamptz default now()
# );

# Admin access: comma-separated list of admin emails who can access `/admin`.
# Example:
# NEXT_PUBLIC_ADMIN_EMAILS=admin@example.com,ops@example.com
